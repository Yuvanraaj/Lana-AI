# ══════════════════════════════════════════════════════════════════════════════
#  LANA AI — Single Environment Configuration
#  Copy this file to .env and fill in your real values.
#  .env is gitignored and must never be committed.
# ══════════════════════════════════════════════════════════════════════════════


# ─── NODE.JS BACKEND (Interview Bot) ──────────────────────────────────────────

NODE_ENV=production
PORT=8001
DEBUG_WS=false

# OpenAI — shared by both backends
OPENAI_API_KEY=sk-proj-your_openai_key_here

# ElevenLabs text-to-speech
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=alloy

# Anam Avatar AI
ANAM_API_KEY=your_anam_api_key_here
ANAM_AVATAR_ID=your_anam_avatar_id_here
ANAM_VOICE_ID=your_anam_voice_id_here
ANAM_LLM_ID=your_anam_llm_id_here


# ─── PYTHON BACKEND (Resume Analyzer) ─────────────────────────────────────────

RESUME_API_PORT=8000

# PostgreSQL — Supabase (or any Postgres provider)
# Get this from: Supabase Dashboard → Project → Settings → Database → Connection string (URI)
# Format: postgresql://postgres:[password]@[host]:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# JWT & auth
JWT_SECRET_KEY=change-me-in-production-use-64-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin dashboard access
ADMIN_EMAILS=admin@example.com

# Admin account auto-created on first startup (set in Render environment variables)
ADMIN_EMAIL=your_admin_email@gmail.com
ADMIN_PASSWORD=YourStr0ng!Password
ADMIN_NAME=Lana Admin

# OpenAI model settings (key shared from above section)
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# CORS — add your production domain here when deploying
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173


# ─── FRONTEND BUILD ARGS (React / Vite) ────────────────────────────────────────
#
# Docker (nginx proxy): leave BOTH empty — nginx routes /api/ and /resume-api/
#   VITE_API_BASE_URL=
#   VITE_RESUME_API_URL=
#
# Non-Docker production (Render / Vercel): set to your deployed URLs
#   VITE_API_BASE_URL=https://your-node-backend.onrender.com
#   VITE_RESUME_API_URL=https://your-python-backend.onrender.com
#
VITE_API_BASE_URL=
VITE_RESUME_API_URL=
